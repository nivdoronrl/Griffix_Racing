# ── Server ────────────────────────────────────────────
PORT=3000

# ── Shippo Shipping ────────────────────────────────────
# Get your key at https://goshippo.com → Settings → API
SHIPPO_API_KEY=shippo_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
SHIPPO_FROM_NAME=Your Business Name
SHIPPO_FROM_STREET=123 Your Street
SHIPPO_FROM_CITY=Your City
SHIPPO_FROM_STATE=Your State
SHIPPO_FROM_ZIP=00000
SHIPPO_FROM_COUNTRY=US
SHIPPO_FROM_PHONE=+10000000000

# ── Email (Gmail SMTP) ─────────────────────────────────
# Use a Gmail App Password (not your login password)
# Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
OWNER_EMAIL=your@gmail.com

# ── Payments (links only — no gateway) ────────────────
# e.g. https://www.paypal.me/YourName
PAYPAL_ME_URL=https://www.paypal.me/YourName

# ── Admin ──────────────────────────────────────────────
# The password you will enter on the admin login page
ADMIN_PASSWORD=your-admin-password
# A long random secret used to sign admin tokens (generate with: openssl rand -hex 32)
ADMIN_SECRET=

# -- GitHub Data Sync (free alternative to a paid persistent disk) -----
# Free hosting tiers (Render, Railway, etc.) wipe local disk on every
# restart/redeploy. Setting these three vars makes every admin save also
# commit products.json/gallery.json to a dedicated branch in this GitHub
# repo, and makes the server restore the latest saved data from that
# branch on every boot -- so your catalog survives resets with no paid
# disk or database needed.
#
# 1. Generate a token: GitHub -> Settings -> Developer settings ->
#    Personal access tokens -> Fine-grained tokens -> New token.
#    Scope it to ONLY this repository, with "Contents: Read and write"
#    permission.
# 2. Paste the token below (and set the same 3 vars in your hosting
#    provider's environment variable settings -- not just here).
GITHUB_TOKEN=
GITHUB_REPO=nivdoronrl/Griffix_Racing
GITHUB_DATA_BRANCH=shop-data
