      <div class="gallery-img" style="height:260px;">
        <img src="https://images.pexels.com/photos/3536269/pexels-photo-3536269.jpeg?auto=compress&cs=tinysrgb&w=600&h=520&fit=crop"
             alt="Griffix Racing — custom dirt bike kit" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'">
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
        <div class="absolute inset-0" style="background:radial-gradient(ellipse at 30% 30%, rgba(255,107,0,.09) 0%, transparent 50%);"></div>
        <div class="lime-tint"></div>
      </div>
    </div>

    <div class="text-center mt-8">
      <a href="https://www.facebook.com/GriffixRacing" target="_blank" rel="noopener" class="btn-ghost">Follow @GriffixRacing</a>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     NEWSLETTER
═══════════════════════════════════════════════ -->
<section style="padding:96px 0; background:#0a0a0a; position:relative; overflow:hidden;" class="topo grain" id="contact">
  <div class="carbon absolute inset-0" style="opacity:.25;"></div>
  <div class="absolute inset-0" style="background:radial-gradient(ellipse 80% 60% at 50% 0%, rgba(163,145,113,.10) 0%, transparent 55%);"></div>

  <div class="relative z-10 max-w-xl mx-auto px-6 text-center">
    <!-- Small logo -->
    <div style="width:56px; height:56px; margin:0 auto 28px;">
      <img src="/brand_assets/Griffix logo.png" alt="Griffix" class="w-full h-full object-contain logo-lime" style="opacity:.55;">
    </div>

    <div class="label mb-5 justify-center">Stay Connected</div>
    <h2 class="font-display font-bold text-white mb-4" style="font-size:clamp(38px,5vw,60px); letter-spacing:-.03em; line-height:.95;">
      JOIN<br><span style="color:#FF6B00;">THE PACK</span>
    </h2>
    <p class="text-[#777] mb-8" style="font-family:'Archivo Narrow',sans-serif; line-height:1.75; font-size:16px;">
      Get early access to new kit drops, exclusive discounts, and race coverage. No spam — just good stuff from the shed.
    </p>

    <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3" onsubmit="(function(e){e.preventDefault();var em=document.getElementById('newsletter-email').value.trim();if(!em||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(em)){return;}var msg=document.getElementById('newsletter-msg');msg.style.display='block';document.getElementById('newsletter-form').style.display='none';})()">
      <input id="newsletter-email" type="email" placeholder="YOUR EMAIL ADDRESS"
        class="flex-1 bg-[#181818] text-[#e5e5e5] placeholder-[#444] px-5 py-3.5 text-sm focus:outline-none"
        style="border:1px solid rgba(163,145,113,.4); font-family:'Archivo Narrow',sans-serif; letter-spacing:.05em;">
      <button type="submit" class="btn-primary" style="padding:14px 24px; font-size:13px;">SUBSCRIBE</button>
    </form>
    <div id="newsletter-msg" style="display:none; color:#FF6B00; font-family:'Oswald',sans-serif; font-size:14px; letter-spacing:.08em; padding:16px 0;">YOU'RE IN. WELCOME TO THE PACK.</div>
    <p class="text-[#444] text-xs mt-4" style="font-family:'Archivo Narrow',sans-serif;">No spam. Unsubscribe anytime. We ride clean.</p>
  </div>
</section>


<div id="footer-placeholder"></div>


<script src="/js/reveal.js"></script>
<script src="/js/cart.js"></script>
<script src="/js/nav.js"></script>
</body>
</html>
