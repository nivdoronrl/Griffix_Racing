        <div class="absolute top-0 left-0 bottom-0" style="width:3px; background:#A39171;"></div>
      </div>

      <!-- Floating stats card -->
      <div class="absolute shadow-tactical" style="right:-20px; bottom:48px; background:#A39171; padding:20px 28px; min-width:170px;">
        <div class="font-display text-[#0f0f0f] font-bold" style="font-size:40px; line-height:1;">15+</div>
        <div class="font-display text-[#0f0f0f] text-sm tracking-wider mt-0.5">YEARS DESIGN</div>
        <div class="text-[#2B2B2B]/80 text-xs mt-1" style="font-family:'Archivo Narrow',sans-serif;">Built by riders</div>
      </div>
    </div>

    <!-- Text side -->
    <div>
      <div class="label mb-5">Our Story</div>
      <h2 class="font-display font-bold text-white mb-7" style="font-size:clamp(38px,4.5vw,56px); letter-spacing:-.03em; line-height:1.0;">
        FORGED IN DIRT.<br>
        <span style="color:#A39171;">PROVEN IN</span><br>
        BATTLE.
      </h2>
      <p class="text-[#909090] mb-5" style="font-size:16px; line-height:1.8; font-family:'Archivo Narrow',sans-serif;">
        Griffix Racing was built by riders who were fed up with generic graphics that didn't survive the first river crossing. We design from the seat of the bike — understanding what it means to take a hit, drag through roots, and still need your machine looking fresh on Sunday.
      </p>
      <p class="text-[#909090] mb-10" style="font-size:16px; line-height:1.8; font-family:'Archivo Narrow',sans-serif;">
        Every kit is printed on Substance Inc. X1 UltraCurve — the industry-leading print media co-developed with factory racing teams — and laminated with UltraCurve 1500 overlaminate. UV resistant. Chemical resistant. Scratch resistant. Built to last a full season in the gnarliest conditions on earth.
      </p>

      <!-- Feature list -->
      <div class="space-y-5 mb-10">
        <div class="flex items-start gap-4">
          <div class="check-icon mt-0.5">
            <svg width="12" height="12" fill="none" stroke="#0f0f0f" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="font-display text-white font-bold text-sm tracking-wide mb-0.5">Substance Inc. X1 UltraCurve Print Media</div>
            <div class="text-[#777] text-sm" style="font-family:'Archivo Narrow',sans-serif;">Ultra-aggressive FLO Technology adhesive — more than double the bond to low surface energy plastics. Bubble-free installation.</div>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="check-icon mt-0.5">
            <svg width="12" height="12" fill="none" stroke="#0f0f0f" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="font-display text-white font-bold text-sm tracking-wide mb-0.5">UV & Chemical Resistant</div>
            <div class="text-[#777] text-sm" style="font-family:'Archivo Narrow',sans-serif;">Won't fade in sun, mud, or fuel. Season after season.</div>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="check-icon mt-0.5">
            <svg width="12" height="12" fill="none" stroke="#0f0f0f" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
