<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Griffix Racing — Premium Motocross Graphics Kits & Seat Covers</title>
  <meta name="description" content="Premium motocross and enduro graphics kits, seat covers, and accessories. Built for hard enduro and MX riders. Printed on Substance Inc. X1 UltraCurve with UltraCurve 1500 overlaminate, UV resistant, 48hr dispatch. KTM, Husqvarna, Yamaha, Honda and more.">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Archivo+Narrow:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            charcoal: { DEFAULT: '#2B2B2B', 700: '#353535', 800: '#1E1E1E', 900: '#141414' },
            orange: { DEFAULT: '#FF6B00', dark: '#e55a00' },
            tan: { DEFAULT: '#A39171', dark: '#7D6E56' }
          },
          fontFamily: {
            display: ['Oswald', 'sans-serif'],
            body: ['Archivo Narrow', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/shared/theme.css">
</head>
<body>

<div id="nav-placeholder"></div>


<!-- ═══════════════════════════════════════════════
     HERO
═══════════════════════════════════════════════ -->
<section class="relative topo" style="min-height: 100vh; background: #0f0f0f; padding-top: 64px; overflow: hidden;">

  <!-- Ambient gradients -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 65% 35%, rgba(255,107,0,.03) 0%, transparent 60%), radial-gradient(ellipse 70% 65% at 8% 75%, rgba(163,145,113,.13) 0%, transparent 55%), radial-gradient(ellipse 45% 40% at 28% 45%, rgba(163,145,113,.07) 0%, transparent 50%);"></div>

  <!-- Carbon strip left -->
  <div class="carbon absolute left-0 top-0 bottom-0 hidden lg:block" style="width: 44%; opacity: .28;"></div>

  <!-- Diagonal accent line -->
  <div class="absolute hidden lg:block" style="top:0; left:44%; bottom:0; width:2px; background:linear-gradient(to bottom, transparent 0%, rgba(255,107,0,.15) 30%, rgba(255,107,0,.4) 50%, rgba(255,107,0,.15) 70%, transparent 100%); transform:skewX(-3deg);"></div>

  <!-- Topographic terrain background — Coyote Tan contour lines behind hero title -->
  <div class="absolute" style="left:0; top:0; width:52%; height:100%; z-index:2; pointer-events:none; overflow:hidden;">
    <svg viewBox="0 0 660 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" style="width:100%; height:100%;">
      <!-- Main topo group — peak anchored at (290, 540) lower-left of hero text -->
      <g fill="none">
        <!-- Inner dense rings — steep summit terrain -->
        <ellipse cx="290" cy="540" rx="20" ry="13" stroke="#C4AA84" stroke-width="1.8" opacity="0.55" transform="rotate(-10 290 540)"/>
        <ellipse cx="290" cy="540" rx="45" ry="30" stroke="#C4AA84" stroke-width="1.6" opacity="0.48" transform="rotate(-10 290 540)"/>
        <ellipse cx="290" cy="540" rx="78" ry="52" stroke="#B8A07A" stroke-width="1.4" opacity="0.40" transform="rotate(-11 290 540)"/>
        <ellipse cx="290" cy="540" rx="118" ry="80" stroke="#B8A07A" stroke-width="1.3" opacity="0.33" transform="rotate(-11 290 540)"/>
        <!-- Mid rings — gradual descent -->
        <ellipse cx="290" cy="540" rx="164" ry="112" stroke="#A39171" stroke-width="1.1" opacity="0.26" transform="rotate(-13 290 540)"/>
        <ellipse cx="290" cy="540" rx="218" ry="150" stroke="#A39171" stroke-width="1.0" opacity="0.21" transform="rotate(-13 290 540)"/>
        <ellipse cx="290" cy="540" rx="278" ry="193" stroke="#A39171" stroke-width="0.9" opacity="0.17" transform="rotate(-14 290 540)"/>
        <!-- Outer rings — wide valley floor -->
        <ellipse cx="290" cy="540" rx="346" ry="242" stroke="#A39171" stroke-width="0.8" opacity="0.13" transform="rotate(-14 290 540)"/>
        <ellipse cx="290" cy="540" rx="420" ry="298" stroke="#917D5F" stroke-width="0.75" opacity="0.10" transform="rotate(-15 290 540)"/>
        <ellipse cx="290" cy="540" rx="502" ry="358" stroke="#917D5F" stroke-width="0.65" opacity="0.07" transform="rotate(-15 290 540)"/>
        <ellipse cx="290" cy="540" rx="590" ry="424" stroke="#917D5F" stroke-width="0.6" opacity="0.05" transform="rotate(-15 290 540)"/>
        <!-- Secondary ridge offset slightly — creates realistic saddle terrain -->
        <ellipse cx="380" cy="480" rx="60" ry="36" stroke="#A39171" stroke-width="1.0" opacity="0.18" transform="rotate(-20 380 480)"/>
        <ellipse cx="380" cy="480" rx="108" ry="66" stroke="#A39171" stroke-width="0.8" opacity="0.13" transform="rotate(-20 380 480)"/>
        <ellipse cx="180" cy="620" rx="50" ry="30" stroke="#A39171" stroke-width="0.9" opacity="0.15" transform="rotate(-5 180 620)"/>
        <ellipse cx="180" cy="620" rx="90" ry="55" stroke="#A39171" stroke-width="0.7" opacity="0.10" transform="rotate(-5 180 620)"/>
      </g>
      <!-- Elevation tick marks — military survey style -->
      <line x1="270" y1="540" x2="256" y2="534" stroke="#C4AA84" stroke-width="0.8" opacity="0.55"/>
      <line x1="310" y1="537" x2="324" y2="531" stroke="#C4AA84" stroke-width="0.8" opacity="0.48"/>
      <line x1="242" y1="568" x2="228" y2="574" stroke="#B8A07A" stroke-width="0.7" opacity="0.38"/>
      <line x1="338" y1="562" x2="352" y2="568" stroke="#B8A07A" stroke-width="0.7" opacity="0.32"/>
      <!-- Elevation labels — tactical survey numbers -->
      <text x="264" y="538" fill="#C4AA84" font-size="8" opacity="0.60" font-family="'Courier New', monospace" letter-spacing="1.5">2847</text>
      <text x="222" y="584" fill="#B8A07A" font-size="7.5" opacity="0.46" font-family="'Courier New', monospace" letter-spacing="1.5">2720</text>
      <text x="176" y="638" fill="#A39171" font-size="7" opacity="0.35" font-family="'Courier New', monospace" letter-spacing="1.5">2600</text>
      <text x="120" y="696" fill="#A39171" font-size="6.5" opacity="0.25" font-family="'Courier New', monospace" letter-spacing="1.5">2480</text>
      <text x="68" y="756" fill="#917D5F" font-size="6" opacity="0.18" font-family="'Courier New', monospace" letter-spacing="1.5">2360</text>
      <!-- Ridge indicator lines — dashed survey path -->
      <line x1="272" y1="532" x2="230" y2="500" stroke="#C4AA84" stroke-width="0.8" opacity="0.32" stroke-dasharray="3,4"/>
      <line x1="230" y1="500" x2="185" y2="462" stroke="#B8A07A" stroke-width="0.7" opacity="0.22" stroke-dasharray="3,4"/>
      <line x1="185" y1="462" x2="148" y2="428" stroke="#A39171" stroke-width="0.6" opacity="0.15" stroke-dasharray="3,4"/>
      <!-- Cross-hairs at summit -->
      <line x1="290" y1="524" x2="290" y2="556" stroke="#D4C8A8" stroke-width="1.0" opacity="0.55"/>
      <line x1="274" y1="540" x2="306" y2="540" stroke="#D4C8A8" stroke-width="1.0" opacity="0.55"/>
      <circle cx="290" cy="540" r="4" fill="none" stroke="#C4AA84" stroke-width="1.2" opacity="0.55"/>
      <circle cx="290" cy="540" r="1.5" fill="#C4AA84" opacity="0.60"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-10 items-center min-h-[calc(100vh-64px)] py-16">

    <!-- LEFT: Copy -->
    <div>
      <div class="label mb-8">Motocross & Enduro Graphics</div>

      <h1 class="font-display font-bold text-white mb-7" style="font-size:clamp(56px,8.5vw,104px); line-height:.9; letter-spacing:-.03em;">
        BUILT<br>
        <span class="clip-lime">FOR THE</span><br>
        BRUTAL.
      </h1>

      <p class="text-[#909090] mb-9 max-w-[440px]" style="font-size:17px; line-height:1.75; font-family:'Archivo Narrow',sans-serif;">
        Premium graphics kits engineered for hard enduro, motocross, and woods riders who take no prisoners. Race-ready designs that hold up where others fail.
      </p>

      <div class="flex flex-wrap gap-4 mb-14">
        <a href="/shop.html?category=graphic-kit" class="btn-primary">Shop Kits</a>
        <a href="/gallery.html" class="btn-ghost">View Gallery</a>
      </div>

      <!-- Stats -->
      <div class="flex flex-wrap gap-10">
        <div class="stat-bar">
          <div class="font-display font-bold" style="font-size:28px; color:#A39171;">5,000+</div>
          <div class="text-[#666] text-xs uppercase tracking-widest mt-0.5" style="font-family:'Archivo Narrow',sans-serif;">Kits Shipped</div>
        </div>
        <div class="stat-bar">
          <div class="font-display font-bold" style="font-size:28px; color:#A39171;">12+</div>
          <div class="text-[#666] text-xs uppercase tracking-widest mt-0.5" style="font-family:'Archivo Narrow',sans-serif;">Countries</div>
        </div>
        <div class="stat-bar">
          <div class="font-display font-bold" style="font-size:28px; color:#A39171;">48hr</div>
          <div class="text-[#666] text-xs uppercase tracking-widest mt-0.5" style="font-family:'Archivo Narrow',sans-serif;">Dispatch</div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Hero image -->
    <div class="relative">
      <div class="relative overflow-hidden" style="height:600px; border-radius:2px;">
        <!-- Motocross dirt bike action photo (Pexels 564094) -->
        <img src="https://images.pexels.com/photos/564094/pexels-photo-564094.jpeg?auto=compress&cs=tinysrgb&w=1200&h=1200&fit=crop"
             alt="Motocross rider in full send — Griffix Racing 2025 kit"
             class="absolute inset-0 w-full h-full object-cover"
             style="object-position:center center;"
             onerror="this.style.display='none'">
        <!-- Carbon base (shows if image fails) -->
        <div class="absolute inset-0 carbon" style="opacity:.8;"></div>
        <!-- Brutal color treatment: orange tint + grit -->
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,107,0,.22) 0%, transparent 55%), radial-gradient(ellipse at 60% 30%, rgba(255,107,0,.12) 0%, transparent 55%); mix-blend-mode: multiply;"></div>
        <!-- Deep shadow gradient from bottom -->
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,15,15,.10) 0%, transparent 35%, rgba(15,15,15,.80) 100%);"></div>
        <!-- Diagonal slash accent -->
        <div class="absolute" style="top:0;right:0;bottom:0;width:3px;background:linear-gradient(to bottom, transparent,rgba(255,107,0,.6) 40%,rgba(255,107,0,.6) 60%,transparent);"></div>
        <!-- Season badge bottom-left -->
        <div class="absolute bottom-14 left-6 z-10">
          <div class="font-display font-bold text-white/90 uppercase tracking-widest" style="font-size:11px; letter-spacing:.18em; color:#C4AA84;">Season</div>
          <div class="font-display font-bold text-white" style="font-size:38px; line-height:.9; letter-spacing:-.03em;">2025<br><span style="color:#FF6B00;">KITS</span></div>
        </div>
        <!-- Lime base bar -->
        <div class="absolute bottom-0 left-0 right-0" style="height:3px; background:#FF6B00;"></div>
      </div>

      <!-- Floating badge -->
      <a href="/shop.html" class="absolute shadow-tactical" style="left:-18px; top:36px; background:#FF6B00; padding:14px 22px; clip-path:polygon(0 0, 100% 0, 93% 50%, 100% 100%, 0 100%); text-decoration:none; display:block;">
        <div class="font-display text-[#0f0f0f] font-bold text-sm tracking-widest leading-tight">NEW SEASON</div>
        <div class="font-display text-[#0f0f0f] text-xs tracking-wider">2025 KITS</div>
      </a>

      <!-- Bottom floating spec pill -->
      <div class="absolute bottom-6 right-6 flex items-center gap-3 px-4 py-3" style="background:rgba(15,15,15,.9); border:1px solid rgba(163,145,113,.4); backdrop-filter:blur(8px);">
        <svg width="18" height="18" fill="none" stroke="#FF6B00" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="text-white text-xs uppercase tracking-wider" style="font-family:'Oswald',sans-serif;">X1 UltraCurve · UV Rated</span>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10">
    <span class="text-[#555] text-xs uppercase tracking-widest" style="font-family:'Archivo Narrow',sans-serif;">Scroll</span>
    <div style="width:1px; height:40px; background:linear-gradient(to bottom, #555, transparent);"></div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     MARQUEE TICKER
═══════════════════════════════════════════════ -->
<div class="marquee-wrap relative z-20" style="background:#1a1a1a; padding:9px 0; overflow:hidden; border-top:1px solid rgba(163,145,113,.4); border-bottom:1px solid rgba(163,145,113,.4);">
  <div class="marquee-track">
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> GRAPHIC KITS</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> SEAT COVERS</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> MOTO ACCESSORIES</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> CUSTOM DESIGNS</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> FREE SHIPPING OVER $150 USD</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> RACE-PROVEN QUALITY</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> GRAPHIC KITS</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> SEAT COVERS</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> MOTO ACCESSORIES</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> CUSTOM DESIGNS</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> FREE SHIPPING OVER $150 USD</span>
    <span class="font-display font-bold text-sm tracking-widest mx-10" style="color:#C8B89A;"><span style="color:#FF6B00;">◆</span> RACE-PROVEN QUALITY</span>
  </div>
</div>


<!-- ═══════════════════════════════════════════════
     PRODUCT CATEGORIES
═══════════════════════════════════════════════ -->
<section id="categories" style="padding: 96px 0; background: #0f0f0f;">
  <div class="max-w-7xl mx-auto px-6">

    <div class="mb-14">
      <div class="label mb-4">Shop By Category</div>
      <h2 class="font-display font-bold text-white" style="font-size:clamp(38px,5vw,60px); letter-spacing:-.03em;">WHAT WE BUILD</h2>
    </div>

    <!-- 3-col category grid -->
    <div class="grid md:grid-cols-3 gap-1" id="kits" id="seat-covers">

      <!-- Graphic Kits -->
      <a href="/shop.html?category=graphic-kit" class="cat-card shadow-card" style="height:500px; display:block; text-decoration:none;">
        <!-- Motocross rider with full graphics kit (Pexels 776108) -->
        <img src="https://images.pexels.com/photos/776108/pexels-photo-776108.jpeg?auto=compress&cs=tinysrgb&w=800&h=1000&fit=crop"
             alt="Motocross graphic kit" class="absolute inset-0 w-full h-full object-cover"
             onerror="this.style.display='none'">
        <!-- Carbon fallback bg -->
        <div class="absolute inset-0 carbon" style="opacity:.7;"></div>
        <!-- Brand DNA color treatment — orange brutal wash + grain -->
        <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(255,107,0,.35) 0%, rgba(15,15,15,.1) 50%, transparent 100%); mix-blend-mode:multiply;"></div>
        <!-- Ghost category watermark -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-display font-bold text-white/[.06] whitespace-nowrap select-none pointer-events-none" style="font-size:72px; letter-spacing:-.03em;">GRAPHICS</div>
        <div class="overlay"></div>
        <div class="lime-bar"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 z-10">
          <div class="label mb-3" style="color:#FF6B00; font-size:10px;">Category 01</div>
          <h3 class="font-display text-white font-bold mb-2" style="font-size:32px; letter-spacing:-.02em;">Graphic Kits</h3>
          <p class="text-[#ccc] text-sm mb-5" style="font-family:'Archivo Narrow',sans-serif; line-height:1.65;">Full-bike graphics for enduro, MX, and hard enduro. Available for all major makes and models.</p>
          <div class="flex items-center gap-2 text-[#FF6B00] text-sm font-medium" style="font-family:'Oswald',sans-serif; letter-spacing:.1em;">
            SHOP KITS <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <!-- Seat Covers -->
      <a href="/shop.html?category=seat-cover" class="cat-card shadow-card" style="height:500px; display:block; text-decoration:none;">
        <!-- Warm tan fallback bg (behind image) -->
        <div class="absolute inset-0" style="background: #1a1814;"></div>
        <!-- Motocross action — seat & control (Pexels 2745827) -->
        <img src="https://images.pexels.com/photos/2745827/pexels-photo-2745827.jpeg?auto=compress&cs=tinysrgb&w=800&h=1000&fit=crop"
             alt="Seat cover close-up" class="absolute inset-0 w-full h-full object-cover"
             style="object-position:center 30%;"
             onerror="this.style.display='none'">
        <!-- Brand DNA treatment — coyote tan wash -->
        <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(163,145,113,.25) 0%, rgba(15,15,15,.05) 55%, transparent 100%);"></div>
        <div class="absolute font-display font-bold text-white/[.06] select-none pointer-events-none" style="top:50%; left:50%; transform:translate(-50%,-50%); font-size:62px; letter-spacing:-.03em; white-space:nowrap;">SEAT COVERS</div>
        <div class="overlay"></div>
        <div class="lime-bar"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 z-10">
          <div class="label mb-3" style="color:#FF6B00; font-size:10px;">Category 02</div>
          <h3 class="font-display text-white font-bold mb-2" style="font-size:32px; letter-spacing:-.02em;">Seat Covers</h3>
          <p class="text-[#ccc] text-sm mb-5" style="font-family:'Archivo Narrow',sans-serif; line-height:1.65;">Gripper and standard seat covers with matching custom graphics. Tailored to your machine.</p>
          <div class="flex items-center gap-2 text-[#FF6B00] text-sm font-medium" style="font-family:'Oswald',sans-serif; letter-spacing:.1em;">
            SHOP COVERS <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <!-- Accessories -->
      <a href="/shop.html?category=accessory" class="cat-card shadow-card" style="height:500px; display:block; text-decoration:none;">
        <!-- Dark fallback bg (behind image) -->
        <div class="absolute inset-0" style="background:#141414;"></div>
        <!-- Dirt bike close-up — accessories angle (Pexels 3536269) -->
        <img src="https://images.pexels.com/photos/3536269/pexels-photo-3536269.jpeg?auto=compress&cs=tinysrgb&w=800&h=1000&fit=crop"
             alt="Motocross accessories and gear" class="absolute inset-0 w-full h-full object-cover"
             onerror="this.style.display='none'">
        <!-- Brand DNA treatment -->
        <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(43,43,43,.45) 0%, transparent 60%);"></div>
        <!-- Dot grid accent -->
        <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,107,0,.04) 1px, transparent 1px); background-size: 24px 24px;"></div>
        <div class="absolute font-display font-bold text-white/[.06] select-none pointer-events-none" style="top:50%; left:50%; transform:translate(-50%,-50%); font-size:55px; letter-spacing:-.03em; white-space:nowrap;">ACCESSORIES</div>
        <div class="overlay"></div>
        <div class="lime-bar"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 z-10">
          <div class="label mb-3" style="color:#FF6B00; font-size:10px;">Category 03</div>
          <h3 class="font-display text-white font-bold mb-2" style="font-size:32px; letter-spacing:-.02em;">Accessories</h3>
          <p class="text-[#ccc] text-sm mb-5" style="font-family:'Archivo Narrow',sans-serif; line-height:1.65;">Number plates, helmet stickers, fleece wraps and more. Every detail matters on the track.</p>
          <div class="flex items-center gap-2 text-[#FF6B00] text-sm font-medium" style="font-family:'Oswald',sans-serif; letter-spacing:.1em;">
            SHOP ACCESSORIES <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     SHOP BY MAKE
═══════════════════════════════════════════════ -->
<section style="padding: 96px 0; background: #0a0a0a; position:relative; overflow:hidden;">
  <!-- Subtle topo grain in bg -->
  <div class="absolute inset-0 topo" style="opacity:.35;"></div>
  <div class="absolute inset-0" style="background:radial-gradient(ellipse 80% 50% at 50% 0%, rgba(255,107,0,.04) 0%, transparent 60%);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">

    <div class="flex items-end justify-between mb-14">
      <div>
        <div class="label mb-4">Graphics For Your Machine</div>
        <h2 class="font-display font-bold text-white" style="font-size:clamp(38px,5vw,60px); letter-spacing:-.03em;">SHOP BY MAKE</h2>
      </div>
      <a href="/shop.html" class="hidden md:flex items-center gap-2 text-[#FF6B00] text-sm" style="font-family:'Oswald',sans-serif; letter-spacing:.1em; transition:gap .2s ease;" onmouseover="this.style.gap='20px'" onmouseout="this.style.gap=''">
